# Compiled output
**/out/
**/bin/
*.class

# macOS
.DS_Store

# IntelliJ: commit the shared project config (.iml, modules.xml, misc.xml,
# vcs.xml, libraries/) so the project opens & runs on clone, but ignore the
# per-user / high-churn files.
.idea/*
!.idea/libraries/
!.idea/misc.xml
!.idea/modules.xml
!.idea/vcs.xml
.idea/workspace.xml
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/shelf/
.idea/dictionaries/

# VS Code: commit the shared project config so it resolves lib/ on clone,
# but ignore per-user files.
.vscode/*
!.vscode/settings.json
**/.history/
.classpath
.project
.settings/
